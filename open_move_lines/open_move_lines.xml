<tryton>
    <data>
        <record model="ir.ui.view" id="print_open_move_lines_start_view_form">
            <field name="model">account_reports.print_open_move_lines.start</field>
            <field name="type">form</field>
            <field name="name">print_open_move_lines_start_form</field>
        </record>
        <record model="ir.action.wizard" id="wizard_print_open_move_lines">
            <field name="name">Print Open Move Lines</field>
            <field name="wiz_name">account_reports.print_open_move_lines</field>
        </record>

        <record model="html.template" id="open_move_lines_html_header_template">
            <field name="name">Header</field>
            <field name="type">header</field>
            <field name="sequence" eval="99"/>
            <field name="filename">account_reports/open_move_lines/templates/header_macro.html</field>
        </record>
        <record model="html.template" id="open_move_lines_html_template">
            <field name="name">Open Move Lines</field>
            <field name="type">base</field>
            <field name="sequence" eval="99"/>
            <field name="filename">account_reports/open_move_lines/templates/open_move_lines.html</field>
        </record>

        <record model="ir.action.report" id="report_open_move_lines">
            <field name="name">Open Move Lines</field>
            <field name="report_name">account_reports.open_move_lines</field>
            <field name="html_template" ref="open_move_lines_html_template"/>
            <field name="html_header_template" ref="open_move_lines_html_header_template"/>
            <field name="extension">pdf</field>
            <field name="template_extension">jinja</field>
        </record>

        <record model="html.template.signature" id="open_move_lines_show_detail_macro_signature">
            <field name="name">show_detail(records, format)</field>
        </record>
        <record model="html.template" id="open_move_lines_show_detail_macro_html">
            <field name="name">Open Move Lines Detail</field>
            <field name="type">macro</field>
            <field name="sequence" eval="99"/>
            <field name="filename">account_reports/open_move_lines/templates/detail_macro.html</field>
            <field name="implements" ref="account_reports.open_move_lines_show_detail_macro_signature"/>
        </record>
        <record model="html.report.template" id="report_open_move_lines_template_show_detail_html">
            <field name="report" ref="report_open_move_lines"/>
            <field name="signature" ref="open_move_lines_show_detail_macro_signature"/>
        </record>

        <record model="html.template.signature" id="open_move_lines_show_detail_lines_macro_signature">
            <field name="name">show_detail_lines(record)</field>
        </record>
        <record model="html.template" id="open_move_lines_show_detail_lines_macro_html">
            <field name="name">Open Move Lines Detail Lines</field>
            <field name="type">macro</field>
            <field name="sequence" eval="99"/>
            <field name="filename">account_reports/open_move_lines/templates/detail_lines_macro.html</field>
            <field name="implements" ref="account_reports.open_move_lines_show_detail_lines_macro_signature"/>
        </record>
        <record model="html.report.template" id="report_open_move_lines_template_show_detail_lines_html">
            <field name="report" ref="report_open_move_lines"/>
            <field name="signature" ref="open_move_lines_show_detail_lines_macro_signature"/>
        </record>

        <menuitem id="menu_print_open_move_lines" name="Print Open Move Lines"
            parent="account.menu_reporting" action="wizard_print_open_move_lines"
            icon="tryton-print"/>
    </data>
</tryton>
